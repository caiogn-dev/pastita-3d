# =============================================================================
# PASTITA 3D - CUSTOMER FRONTEND CONFIGURATION
# =============================================================================
# Copy this file to .env.local and fill in the values
# =============================================================================

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# API URL - Points to the Pastita backend server
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1/ecommerce

# Media URL - For product images and other media files
# If not set, defaults to API_BASE_URL
NEXT_PUBLIC_MEDIA_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# WebSocket Configuration
# -----------------------------------------------------------------------------
# WebSocket URL for real-time notifications
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Auth cookie name
NEXT_PUBLIC_AUTH_COOKIE_NAME=auth_token

# -----------------------------------------------------------------------------
# Payment Gateway
# -----------------------------------------------------------------------------
# Mercado Pago Public Key (for card payments)
# Get your key at: https://www.mercadopago.com.br/developers/panel/credentials
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# -----------------------------------------------------------------------------
# HERE Maps API (Required for map functionality)
# -----------------------------------------------------------------------------
# HERE Maps API Key for map display, routing, geocoding, and isoline services
# Get your key at: https://platform.here.com/
# Required services: Vector Tile, Routing, Isoline Routing, Geocoding & Search
# Free tier: 250,000 transactions/month
NEXT_PUBLIC_HERE_API_KEY=your-here-api-key

# -----------------------------------------------------------------------------
# Store Information
# -----------------------------------------------------------------------------
# Physical store address for pickup orders
NEXT_PUBLIC_STORE_ADDRESS=Q. 112 Sul Rua SR 1, conj. 06 lote 04 - Plano Diretor Sul
NEXT_PUBLIC_STORE_CITY=Palmas
NEXT_PUBLIC_STORE_STATE=TO
NEXT_PUBLIC_STORE_ZIP=77020-170
# Store coordinates (latitude,longitude)
NEXT_PUBLIC_STORE_LAT=-10.1847
NEXT_PUBLIC_STORE_LNG=-48.3337

# -----------------------------------------------------------------------------
# Contact Information
# -----------------------------------------------------------------------------
# Contact email displayed in footer
NEXT_PUBLIC_CONTACT_EMAIL=contato@pastita.com.br

# WhatsApp number for customer support (without + or spaces)
NEXT_PUBLIC_WHATSAPP_NUMBER=556391172166

# =============================================================================
# PRODUCTION CONFIGURATION
# =============================================================================
# Uncomment and update for production deployment:
# NEXT_PUBLIC_API_URL=https://api.pastita.com.br/api/v1/ecommerce
# NEXT_PUBLIC_MEDIA_URL=https://api.pastita.com.br
# NEXT_PUBLIC_WS_URL=wss://api.pastita.com.br/ws
# NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# NEXT_PUBLIC_HERE_API_KEY=your-production-here-api-key
# =============================================================================
